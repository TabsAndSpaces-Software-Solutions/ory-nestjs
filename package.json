{
  "name": "ory-nestjs",
  "version": "0.1.0",
  "description": "ory-nestjs — NestJS wrapper library for the Ory Stack (self-hosted or Ory Cloud). Abstracts Ory away from consumers.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TabsAndSpaces-Software-Solutions/ory-nestjs.git"
  },
  "bugs": {
    "url": "https://github.com/TabsAndSpaces-Software-Solutions/ory-nestjs/issues"
  },
  "homepage": "https://github.com/TabsAndSpaces-Software-Solutions/ory-nestjs#readme",
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "test:integration": "jest --config jest.integration.config.js --runInBand",
    "lint": "eslint \"src/**/*.ts\"",
    "check:types-exports": "attw --pack ."
  },
  "dependencies": {
    "@ory/client": "^1.15.0",
    "axios": "^1.15.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^29.5.12",
    "@types/node": "^22.0.0",
    "@types/supertest": "^7.2.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nock": "^14.0.12",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "supertest": "^7.2.2",
    "testcontainers": "^10.28.0",
    "ts-jest": "^29.1.5",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4"
  }
}
